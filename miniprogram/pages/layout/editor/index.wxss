/* 摆台编辑器 — 全屏画布 */
page { height: 100%; }
.editor-page { position: relative; height: 100%; background: #FFFFFF; }

/* === 全屏画布 === */
.canvas { width: 100%; height: 100%; background: #FAFBFC; }
.grid-bg {
  position: absolute; top: 0; left: 0; z-index: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(0,0,0,0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0,0,0,0.03) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
}
.canvas-hint {
  display: flex; align-items: center; justify-content: center;
  width: 100%; height: 100%; font-size: 24rpx; color: #9EA395;
  text-align: center; padding: 0 100rpx;
}
.furniture { border-radius: 14rpx; }
.furniture-inner {
  width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
  border-radius: 14rpx; border: 1.5rpx solid #C5C9BE; box-sizing: border-box;
  background: #FFFFFF;
}
.furniture.selected .furniture-inner { border: 2.5rpx solid #8C9E7A; box-shadow: 0 0 0 6rpx rgba(140,158,122,0.10); }
.furniture-label-inner {
  font-size: 16rpx; color: #6B7265; pointer-events: none;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* === 顶部浮动栏 === */
.top-bar {
  position: absolute; top: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 12rpx 16rpx; gap: 10rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  z-index: 10;
  border-bottom: 1rpx solid #F3F2EE;
}
.name-input {
  flex: 1; height: 56rpx; font-size: 26rpx;
  background: #F3F2EE; border-radius: 16rpx; padding: 0 12rpx;
  color: #1A1A1A;
}
.icon-btn {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; background: #F3F2EE; color: #6B7265;
  padding: 0; line-height: 1; box-sizing: border-box; flex-shrink: 0;
}
.icon-btn.primary { background: linear-gradient(135deg, #A8B89A, #8C9E7A); color: #FFFFFF; }
.icon-btn.danger { background: #FFECEA; color: #B5554F; }

/* === 底部浮动栏 === */
.bottom-bar {
  position: absolute; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 10rpx 16rpx; gap: 10rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  z-index: 10;
  border-top: 1rpx solid #F3F2EE;
}
.stat-text { font-size: 22rpx; color: #9EA395; flex: 1; }
.btn-mini {
  height: 48rpx; padding: 0 16rpx; font-size: 22rpx;
  background: #F3F2EE; color: #6B7265; border-radius: 100rpx;
  display: flex; align-items: center; justify-content: center;
  box-sizing: border-box; flex-shrink: 0;
  font-weight: 500;
}
.btn-mini.primary { background: linear-gradient(135deg, #A8B89A, #8C9E7A); color: #FFFFFF; }

/* === 选中浮动操作 === */
.float-actions {
  position: absolute; top: 76rpx; left: 50%; transform: translateX(-50%);
  z-index: 10; background: rgba(255,255,255,0.96);
  border-radius: 16rpx; padding: 8rpx 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(44,51,40,0.10);
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
}
.float-info { font-size: 20rpx; color: #8C9E7A; font-weight: 600; white-space: nowrap; }
.float-btns { display: flex; gap: 8rpx; }

/* === 左侧抽屉 === */
.drawer-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(44,51,40,0.45); z-index: 100;
}
.drawer-panel {
  position: absolute; top: 0; left: 0; bottom: 0;
  width: 340rpx; background: #FFFFFF;
  overflow-y: auto; padding: 24rpx;
}
.drawer-title { font-size: 28rpx; font-weight: 700; color: #2C3328; margin-bottom: 16rpx; }
.group-label { font-size: 20rpx; color: #9EA395; margin-top: 16rpx; margin-bottom: 8rpx; font-weight: 600; }
.furniture-grid { display: flex; flex-wrap: wrap; gap: 8rpx; }
.furniture-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 8rpx; border: 1rpx solid #E8E5DF; border-radius: 14rpx;
  width: 120rpx; background: #FFFFFF;
}
.furniture-item:active { background: #F2F4ED; }
.furniture-preview {
  position: relative; border-radius: 2rpx; margin-bottom: 4rpx;
  display: flex; align-items: center; justify-content: center;
}
.type-count {
  position: absolute; bottom: 1rpx; right: 1rpx;
  background: rgba(44,51,40,0.65); color: #FFFFFF;
  font-size: 14rpx; padding: 0 6rpx; border-radius: 10rpx;
}
.furniture-label { font-size: 16rpx; color: #6B7265; text-align: center; line-height: 1.2; }
.template-item {
  padding: 16rpx 24rpx; margin-bottom: 8rpx;
  background: #FAF9F6; border-radius: 14rpx;
  font-size: 24rpx; color: #1A1A1A; font-weight: 500;
}
.template-item:active { background: #F2F4ED; }

/* === 警告浮层 === */
.warning-float {
  position: absolute; bottom: 72rpx; left: 50%; transform: translateX(-50%);
  z-index: 10; background: rgba(204,122,0,0.94); color: #FFFFFF;
  font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 100rpx;
  font-weight: 500;
}

/* === 物料弹窗 === */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(44,51,40,0.50); z-index: 200;
  display: flex; align-items: flex-end; justify-content: center;
}
.modal-sheet {
  background: #FFFFFF; border-radius: 28rpx 28rpx 0 0;
  width: 100%; padding: 32rpx; padding-top: 16rpx;
}
.modal-handle {
  width: 56rpx; height: 5rpx; background: #C5C9BE;
  border-radius: 3rpx; margin: 0 auto 24rpx;
}
.modal-title { font-size: 30rpx; font-weight: 700; color: #2C3328; }
.material-list { max-height: 600rpx; overflow-y: auto; }
.material-row {
  padding: 18rpx 0; border-bottom: 1rpx solid #F3F2EE;
  font-size: 28rpx; color: #1A1A1A;
}

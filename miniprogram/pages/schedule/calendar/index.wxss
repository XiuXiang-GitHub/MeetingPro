/* 会议档期月历 */
.page { padding: 0; padding-bottom: 140rpx; }

/* 月份导航 */
.month-nav {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx;
  font-size: 34rpx; font-weight: 800; color: #2C3328;
}
.month-label { font-size: 28rpx; letter-spacing: -0.3rpx; }
.nav-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #FFFFFF; border: 1rpx solid #E8E5DF;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #6B7265;
  transition: background 140ms;
}
.nav-btn:active { background: #F3F2EE; }

/* 星期表头 */
.calendar { margin: 8rpx 24rpx 0; }
.weekday-row { display: flex; }
.weekday-row text { flex: 1; text-align: center; font-size: 22rpx; color: #9EA395; padding: 14rpx 0; font-weight: 600; }

/* 日期网格 */
.day-grid { display: flex; flex-wrap: wrap; }
.day-cell {
  width: calc(100% / 7); aspect-ratio: 1;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; border-radius: 16rpx; margin-bottom: 4rpx;
  position: relative; box-sizing: border-box; font-weight: 500;
}
.day-cell.empty { visibility: hidden; }
.day-cell.free { background: transparent; }
.day-cell.partial { background: #FFF4E5; }
.day-cell.full { background: #FFECEA; }
.day-cell.selected { box-shadow: inset 0 0 0 2.5rpx #8C9E7A; }
.day-cell.today { font-weight: 800; }
.day-cell.today .day-num { color: #8C9E7A; }
.day-num { color: #1A1A1A; }
.day-cell.free .day-num { color: #6B7265; }

/* 详情面板 */
.detail-panel { margin-top: 20rpx; }
.detail-date {
  font-size: 28rpx; font-weight: 700;
  color: #2C3328;
  display: flex; align-items: center; gap: 10rpx;
  padding: 0 32rpx; margin-bottom: 12rpx;
}
.detail-date::before {
  content: '';
  display: inline-block;
  width: 6rpx; height: 22rpx; border-radius: 3rpx;
  background: linear-gradient(180deg, #A8B89A, #8C9E7A);
}
.booking-item { padding: 20rpx 32rpx; border-bottom: 1rpx solid #F3F2EE; }
.booking-item:last-child { border-bottom: none; }
.booking-title { font-size: 28rpx; font-weight: 600; color: #1A1A1A; }
.booking-meta { font-size: 24rpx; color: #6B7265; margin-top: 6rpx; display: block; }

.fab {
  position: fixed; bottom: 140rpx; right: 32rpx;
  width: 96rpx; height: 96rpx;
  background: linear-gradient(135deg, #A8B89A 0%, #8C9E7A 100%);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 28rpx rgba(140,158,122,0.40);
  z-index: 100;
}

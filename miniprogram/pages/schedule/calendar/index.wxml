<!-- 会议档期月历 -->
<view class="page">
  <view class="month-nav">
    <view class="nav-btn" bindtap="monthNav" data-dir="prev"><text>‹</text></view>
    <text class="month-label">{{year}}年{{month}}月</text>
    <view class="nav-btn" bindtap="monthNav" data-dir="next"><text>›</text></view>
  </view>

  <view class="calendar">
    <view class="weekday-row">
      <text wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="day-grid">
      <view
        wx:for="{{grid}}" wx:key="index"
        class="day-cell {{item.day === 0 ? 'empty' : ''}} {{item.status}} {{item.dateStr === selectedDate ? 'selected' : ''}}"
        bindtap="onSelectDate" data-date-str="{{item.dateStr}}"
      >
        <text wx:if="{{item.day > 0}}" class="day-num">{{item.day}}</text>
      </view>
    </view>
  </view>

  <!-- 选中日详情 -->
  <view wx:if="{{selectedDate}}" class="detail-panel card">
    <text class="detail-date">{{selectedDate}}</text>
    <block wx:if="{{bookingsOnDate.length === 0}}">
      <view class="empty-state" style="padding:20rpx">
        <view class="empty-state-text">当天无会议</view>
      </view>
    </block>
    <block wx:else>
      <view class="booking-item" wx:for="{{bookingsOnDate}}" wx:key="_id" bindlongpress="onDeleteBooking" data-id="{{item._id}}" data-title="{{item.title}}">
        <view class="flex-between">
          <text class="booking-title">{{item.title}}</text>
          <text class="tag tag-info">{{item.timeSlot}}</text>
        </view>
        <text class="booking-meta">{{item.company || '未关联客户'}} · {{item.attendees}}人</text>
      </view>
    </block>
  </view>

  <view class="fab" bindtap="onAddBooking">+</view>
</view>

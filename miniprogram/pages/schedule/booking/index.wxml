<!-- 新建预定 -->
<view class="page">
  <view class="form-group">
    <text class="form-label">场地 *</text>
    <picker value="{{roomIndex}}" range="{{roomList}}" range-key="name" bindchange="onRoomSelect">
      <view class="input-field flex-row">{{roomList[roomIndex].name || '请选择场地'}}</view>
    </picker>
  </view>
  <view class="form-group">
    <text class="form-label">会议名称 *</text>
    <input class="input-field" value="{{form.title}}" bindinput="onInput" data-field="title" placeholder="会议名称" />
  </view>
  <view class="form-group">
    <text class="form-label">日期 *</text>
    <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
      <view class="input-field flex-row">{{form.date || '请选择日期'}}</view>
    </picker>
  </view>
  <view class="form-group">
    <text class="form-label">时段 *</text>
    <picker value="{{timeSlotIndex}}" range="{{timeSlots}}" bindchange="onTimeSlotSelect">
      <view class="input-field flex-row">{{form.timeSlot || '请选择时段'}}</view>
    </picker>
  </view>
  <view class="form-group">
    <text class="form-label">预计人数</text>
    <input class="input-field" value="{{form.attendees}}" bindinput="onInput" data-field="attendees" type="number" placeholder="人数" />
  </view>
  <view class="form-group">
    <text class="form-label">公司名称</text>
    <input class="input-field" value="{{form.company}}" bindinput="onInput" data-field="company" placeholder="客户公司" />
  </view>
  <view class="form-group">
    <text class="form-label">联系人/电话</text>
    <input class="input-field" value="{{form.contact}}" bindinput="onInput" data-field="contact" placeholder="联系人及电话" />
  </view>
  <view style="padding:48rpx">
    <button class="btn btn-primary" bindtap="onSubmit">提交预定</button>
  </view>
</view>

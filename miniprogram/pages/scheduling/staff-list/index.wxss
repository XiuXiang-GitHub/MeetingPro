/* 员工列表 */
.page { padding: 0; padding-bottom: 140rpx; }

.filter-bar { white-space: nowrap; padding: 16rpx 24rpx; margin-bottom: 8rpx; }
.filter-tag {
  display: inline-block; padding: 8rpx 24rpx; margin-right: 12rpx;
  border-radius: 100rpx; font-size: 24rpx; font-weight: 500;
  background: #FFFFFF; border: 1rpx solid #E8E5DF;
  color: #6B7265;
}
.filter-tag.active {
  background: #8C9E7A; color: #FFFFFF; border-color: #8C9E7A;
  box-shadow: 0 2rpx 8rpx rgba(140,158,122,0.25);
}

.staff-name { font-size: 28rpx; font-weight: 600; color: #1A1A1A; }
.staff-meta { font-size: 24rpx; color: #6B7265; margin-top: 6rpx; }
.skills { display: flex; gap: 8rpx; margin-top: 12rpx; flex-wrap: wrap; }

.fab {
  position: fixed; bottom: 140rpx; right: 32rpx;
  width: 96rpx; height: 96rpx;
  background: linear-gradient(135deg, #A8B89A 0%, #8C9E7A 100%);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 28rpx rgba(140,158,122,0.40);
  z-index: 100;
}

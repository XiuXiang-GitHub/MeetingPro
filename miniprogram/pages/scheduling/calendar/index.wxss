/* 排班周历 */
.page { padding: 0; padding-bottom: 140rpx; }

.week-nav {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 28rpx; font-weight: 700; color: #2C3328;
}
.week-label { font-size: 28rpx; }
.nav-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #FFFFFF; border: 1rpx solid #E8E5DF;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #6B7265;
}
.nav-btn:active { background: #F3F2EE; }

.quick-actions { display: flex; gap: 16rpx; padding: 16rpx 24rpx; margin-bottom: 8rpx; }
.quick-actions .btn { flex: 1; height: 72rpx; font-size: 24rpx; }

.day-header-row { display: flex; margin: 0 24rpx 12rpx; }
.day-header-cell { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 16rpx; }
.day-header-cell.today { background: #F2F4ED; }
.day-label { display: block; font-size: 20rpx; color: #9EA395; font-weight: 500; }
.day-num { display: block; font-size: 26rpx; font-weight: 700; color: #1A1A1A; }
.day-header-cell.today .day-num { color: #8C9E7A; }

.room-sections { padding: 0 16rpx; }
.room-section {
  margin: 0 8rpx 20rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E5DF;
  border-radius: 20rpx;
  overflow: hidden;
}
.room-title {
  padding: 14rpx 24rpx;
  font-size: 26rpx; font-weight: 700;
  color: #1A1A1A;
  background: #FAF9F6;
  border-bottom: 1rpx solid #E8E5DF;
  display: flex; align-items: center; gap: 8rpx;
}
.room-title-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%;
  background: #8C9E7A; flex-shrink: 0;
}
.room-grid { display: flex; padding: 10rpx 8rpx; }
.room-day-cell {
  flex: 1; min-height: 80rpx; padding: 4rpx;
  display: flex; flex-direction: column; gap: 4rpx;
}
.room-day-cell.cell-today { background: #FAF9F6; }
.cell-date { display: block; text-align: center; font-size: 20rpx; color: #9EA395; }
.cell-today .cell-date { color: #8C9E7A; font-weight: 700; }
.staff-tag {
  display: block; background: #F2F4ED; color: #8C9E7A;
  font-size: 20rpx; padding: 4rpx 8rpx; border-radius: 6rpx;
  text-align: center; font-weight: 600;
}
.no-staff { display: block; text-align: center; color: #C5C9BE; font-size: 24rpx; line-height: 48rpx; }

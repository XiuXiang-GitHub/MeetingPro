/* 员工详情/编辑 */
.form-group { padding: 24rpx 32rpx; border-bottom: 1rpx solid #F3F2EE; }
.form-label { display: block; font-size: 24rpx; color: #6B7265; margin-bottom: 12rpx; font-weight: 600; }
.input-field {
  width: 100%; height: 80rpx;
  background: #FAF9F6; border: 1rpx solid #E8E5DF;
  border-radius: 16rpx; padding: 0 16rpx;
  font-size: 28rpx; box-sizing: border-box;
  color: #1A1A1A; display: flex; align-items: center;
  transition: border-color 180ms;
}
.input-field:focus { border-color: #8C9E7A; }

.chip-group { display: flex; flex-wrap: wrap; gap: 8rpx; }
.chip {
  padding: 8rpx 20rpx; border-radius: 100rpx; font-size: 24rpx; font-weight: 500;
  background: #FAF9F6; border: 1rpx solid #E8E5DF; color: #6B7265;
}
.chip.active { background: #F2F4ED; color: #8C9E7A; border-color: #8C9E7A; }

.picker-val {
  display: flex; align-items: center; justify-content: space-between;
  height: 80rpx; padding: 0 16rpx;
  background: #FAF9F6; border: 1rpx solid #E8E5DF;
  border-radius: 16rpx; font-size: 28rpx; color: #1A1A1A;
}
.picker-arrow { color: #9EA395; font-size: 32rpx; }

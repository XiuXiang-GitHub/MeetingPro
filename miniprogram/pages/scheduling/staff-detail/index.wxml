<!-- 员工详情/编辑 -->
<view class="page">
  <view class="form-group">
    <text class="form-label">姓名</text>
    <input class="input-field" value="{{form.name}}" bindinput="onInput" data-field="name" placeholder="请输入姓名" />
  </view>
  <view class="form-group">
    <text class="form-label">电话</text>
    <input class="input-field" value="{{form.phone}}" bindinput="onInput" data-field="phone" type="number" placeholder="请输入电话" />
  </view>
  <view class="form-group">
    <text class="form-label">角色</text>
    <view class="chip-group">
      <text
        wx:for="{{roles}}" wx:key="*this"
        class="chip {{form.role === item ? 'active' : ''}}"
        bindtap="onRoleSelect" data-value="{{item}}"
      >{{item}}</text>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">状态</text>
    <view class="chip-group">
      <text
        wx:for="{{statuses}}" wx:key="*this"
        class="chip {{form.status === item ? 'active' : ''}}"
        bindtap="onStatusSelect" data-value="{{item}}"
      >{{item}}</text>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">技能标签</text>
    <view class="flex-row" style="gap:16rpx">
      <input class="input-field flex-1" value="{{skillInput}}" bindinput="onSkillInput" placeholder="输入技能后添加" />
      <button class="btn btn-secondary btn-sm" bindtap="onAddSkill">添加</button>
    </view>
    <view class="chip-group" style="margin-top:16rpx">
      <text wx:for="{{form.skills}}" wx:key="*this" class="chip" bindtap="onRemoveSkill" data-idx="{{index}}">{{item}} ✕</text>
    </view>
  </view>
  <view style="padding:32rpx">
    <button class="btn btn-primary" bindtap="onSave">保存</button>
    <button wx:if="{{isEdit}}" class="btn btn-danger" bindtap="onDelete" style="margin-top:24rpx">删除员工</button>
  </view>
</view>

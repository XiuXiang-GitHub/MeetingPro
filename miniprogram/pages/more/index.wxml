<!-- 更多 — 功能入口网格 -->
<view class="page">
  <view class="grid">
    <view class="grid-item card" wx:for="{{menus}}" wx:key="title" bindtap="onNavigate" data-url="{{item.url}}">
      <view class="grid-icon">{{item.icon}}</view>
      <view class="grid-title">{{item.title}}</view>
      <view class="grid-desc">{{item.desc}}</view>
    </view>
  </view>
</view>

<!-- 数据报表 -->
<view class="page">
  <view class="tab-bar">
    <text class="tab-item {{activeTab === 'room' ? 'active' : ''}}" bindtap="onTab" data-tab="room">场地使用率</text>
    <text class="tab-item {{activeTab === 'staff' ? 'active' : ''}}" bindtap="onTab" data-tab="staff">人员效率</text>
    <text class="tab-item {{activeTab === 'revenue' ? 'active' : ''}}" bindtap="onTab" data-tab="revenue">月度收入</text>
  </view>

  <view wx:if="{{loading}}" class="empty-state"><view class="empty-state-text">加载中...</view></view>

  <block wx:elif="{{activeTab === 'room'}}">
    <view class="card" style="margin-top:24rpx">
      <text class="section-title">场地使用率 — {{month}}</text>
      <canvas wx:if="{{roomUsage.length > 0}}" type="2d" id="usageChart" style="width:100%;height:400rpx"></canvas>
      <view wx:else class="empty-state" style="padding:40rpx"><view class="empty-state-text">暂无数据</view></view>
    </view>
    <view class="card" wx:for="{{roomUsage}}" wx:key="name">
      <view class="flex-between"><text>{{item.name}}</text><text class="stat-num">{{item.usedDays}}天</text></view>
    </view>
  </block>

  <block wx:elif="{{activeTab === 'staff'}}">
    <view class="card" style="margin-top:24rpx">
      <text class="section-title">人员效率 — {{month}}</text>
      <view wx:if="{{staffEfficiency.length === 0}}" class="empty-state" style="padding:40rpx"><view class="empty-state-text">暂无数据</view></view>
    </view>
    <view class="card" wx:for="{{staffEfficiency}}" wx:key="name">
      <view class="flex-between"><view class="flex-col"><text>{{item.name}}</text><text class="staff-role">{{item.role || ''}}</text></view><view class="flex-col" style="text-align:right"><text class="stat-num">{{item.sessions}}场</text><text class="text-sm">{{item.workDays}}天</text></view></view>
    </view>
  </block>

  <block wx:elif="{{activeTab === 'revenue'}}">
    <view class="card" style="margin-top:24rpx">
      <text class="section-title">月度收入汇总 — {{month}}</text>
      <text class="revenue-total">¥{{revenue.total}}</text>
    </view>
    <view class="card" wx:for="{{revenue.records}}" wx:key="_id">
      <view class="flex-between"><text>{{item.note || '收入记录'}}</text><text>¥{{item.amount}}</text></view>
    </view>
  </block>

  <view style="padding:32rpx"><button class="btn btn-secondary" bindtap="onExport">一键导出报表</button></view>
</view>

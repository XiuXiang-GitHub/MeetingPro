/* 物资库存台账 */
.page { padding: 0; padding-bottom: 140rpx; }
.search-bar { padding: 16rpx 24rpx; margin-bottom: 8rpx; }

.mat-name { font-size: 28rpx; font-weight: 600; color: #1A1A1A; }
.mat-unit { font-size: 24rpx; color: #6B7265; margin-top: 6rpx; }

.mat-stock-row { display: flex; align-items: center; gap: 8rpx; margin-top: 8rpx; }
.mat-stock-bar {
  flex: 1; height: 8rpx; background: #E8E5DF; border-radius: 4rpx; overflow: hidden;
}
.mat-stock-fill { height: 100%; border-radius: 4rpx; }
.mat-stock-fill.safe { background: linear-gradient(90deg, #A8B89A, #8C9E7A); }
.mat-stock-fill.warn { background: #FF9500; }
.mat-stock-fill.danger { background: #FF3B30; }

.mat-actions { display: flex; gap: 12rpx; margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid #F3F2EE; }
.card.low-stock { border-left: 6rpx solid #FF3B30; background: #FFFAFA; }

.bottom-btn { text-align: center; padding: 32rpx; }

/* 弹窗 */
.modal-title { font-size: 30rpx; font-weight: 700; color: #2C3328; display: block; margin-bottom: 24rpx; }
.modal .form-group { padding: 14rpx 0; border-bottom: none; }
.modal .form-label { font-size: 24rpx; color: #6B7265; margin-bottom: 8rpx; display: block; font-weight: 600; }
.modal .input-field {
  width: 100%; height: 80rpx;
  background: #FAF9F6; border: 1rpx solid #E8E5DF;
  border-radius: 16rpx; padding: 0 16rpx;
  font-size: 28rpx; box-sizing: border-box;
  display: flex; align-items: center; color: #1A1A1A;
}
